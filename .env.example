# === Application ===
PROJECT_NAME=AI Health Intelligence Platform
LOG_LEVEL=INFO
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTO_MIGRATE=true

# === Database ===
# Local Docker PostgreSQL (recommended for development):
DATABASE_URL=postgresql://healthintel:healthintel_dev@localhost:5432/healthintel
# Neon / Supabase / Cloud:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# === Migrations ===
# Run `alembic upgrade head` from the backend/ directory after first setup.
# Existing migrations: 01_initial_schema → 08_fix_wards_schema

# === Connectors ===
# Demo/synthetic connectors have been removed from runtime.
# Data is loaded via `python run_import.py` from the backend/ directory,
# which fetches from public FHIR/DHIS2 servers and writes to PostgreSQL.
# The import runs once (not a runtime dependency). After import,
# all API queries read from PostgreSQL only.

# FHIR (hospital workspace) — HAPI public R5 server:
CONNECTOR_FHIR_URL=https://hapi.fhir.org/baseR5
CONNECTOR_FHIR_AUTH_TYPE=none
# CONNECTOR_FHIR_TOKEN=your-token-here

# DHIS2 (community workspace) — Sierra Leone demo server:
CONNECTOR_DHIS2_URL=https://play.im.dhis2.org/stable-2-40-12
CONNECTOR_DHIS2_USERNAME=admin
CONNECTOR_DHIS2_PASSWORD=district

# Incomplete connectors (require custom implementation):
# CONNECTOR_OPENMRS_URL=http://localhost:8080/openmrs/ws/rest/v1
# CONNECTOR_OPENMRS_USERNAME=admin
# CONNECTOR_OPENMRS_PASSWORD=Admin123
# CONNECTOR_OPENELIS_URL=https://your-openelis/api

# === Seed Data ===
# To load a static demo snapshot (deprecated), run: python seed.py
# To import from live FHIR + DHIS2 servers, run: python run_import.py

# === AI Backend (Phase 4) ===
# For OpenAI:
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# For OpenRouter (or any OpenAI-compatible endpoint):
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

AGENT_MODEL=openai/gpt-4o
AGENT_TEMPERATURE=0.2

# === CORS ===
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# === Simulation ===
SIMULATION_INTERVAL_SECONDS=5
